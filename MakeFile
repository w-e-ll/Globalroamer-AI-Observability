PYTHON := .venv/Scripts/python.exe
PIP := .venv/Scripts/pip.exe

CONFIG_DIR := etc

.PHONY: help install dev clean ingest analyze report ui workflow cleanup format lint test

help:
	@echo =========================================
	@echo GlobalRoamer AI Observability Layer
	@echo =========================================
	@echo install     - install dependencies
	@echo dev         - install editable package
	@echo ingest      - run ingestion pipeline
	@echo analyze     - run AI analysis pipeline
	@echo report      - generate reports
	@echo ui          - start Streamlit UI
	@echo workflow    - run full workflow
	@echo cleanup     - cleanup old artifacts
	@echo format      - run black + isort
	@echo lint        - run flake8
	@echo test        - run tests
	@echo clean       - cleanup cache/temp files

install:
	$(PIP) install -r requirements.txt

dev:
	$(PIP) install -e .[dev]

ingest:
	$(PYTHON) -m globalroamer_ai.ingest_main \
		--config-dir $(CONFIG_DIR)

analyze:
	$(PYTHON) -m globalroamer_ai.analyze_main \
		--config-dir $(CONFIG_DIR) \
		--top-k 5

report:
	$(PYTHON) -m globalroamer_ai.report_main \
		--config-dir $(CONFIG_DIR) \
		--max-chunks 20

ui:
	streamlit run globalroamer_ai/streamlit_app.py

workflow:
	powershell -ExecutionPolicy Bypass -File .\scripts\run_workflow.ps1

cleanup:
	powershell -ExecutionPolicy Bypass -File .\scripts\cleanup_folders.ps1

format:
	$(PYTHON) -m black globalroamer_ai
	$(PYTHON) -m isort globalroamer_ai

lint:
	$(PYTHON) -m flake8 globalroamer_ai

test:
	$(PYTHON) -m pytest

clean:
	powershell -Command "Get-ChildItem -Path . -Include __pycache__ -Recurse -Directory | Remove-Item -Recurse -Force"
	powershell -Command "Get-ChildItem -Path . -Include *.pyc -Recurse | Remove-Item -Force"
